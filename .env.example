# ── DrukPass Environment Configuration ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Application
APP_NAME=DrukPass
DEBUG=false
ENVIRONMENT=development

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://drukpass:drukpass@localhost:5432/drukpass
DATABASE_SYNC_URL=postgresql://drukpass:drukpass@localhost:5432/drukpass

# Security — generate with: openssl rand -hex 32
SECRET_KEY=change-this-to-a-secure-random-string

# AI Provider (choose one)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here

# Redis
REDIS_URL=redis://localhost:6379

# Frontend
FRONTEND_URL=http://localhost:3000

# WhatsApp (optional — for stakeholder notifications)
# WHATSAPP_TOKEN=your-whatsapp-cloud-api-token
# WHATSAPP_PHONE_ID=your-whatsapp-phone-number-id
